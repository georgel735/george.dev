---
import { Image } from "astro:assets";
import Drivetrain from "../../assets/tethys/drivetrain.png";
---

<div>
  <Image
    class="project-image border border-black"
    src={Drivetrain}
    alt="Tethys Drivetrain!"
    densities={[1, 2, 3]}
  />
</div>

<style>
  .project-image {
    width: 100%;
    height: auto;
  }
</style>