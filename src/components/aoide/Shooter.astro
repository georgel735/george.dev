---
import { Image } from "astro:assets";
import Shooter from "../../assets/aoide/shooter.png";
---

<div>
  <Image
    class="project-image border border-black"
    src={Shooter}
    alt="Aoide Shooter!"
    densities={[1, 2, 3]}
  />
</div>

<style>
  .project-image {
    width: 100%;
    height: auto;
  }
</style>